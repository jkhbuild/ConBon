// ConBon data model.
//
// ID strategy: cuid() for all primary keys. Shorter than uuid, roughly
// sortable by creation time, URL-safe, and Prisma's default. Fine for
// an internal app with no public ID surface.
//
// Schema choices worth noting:
// - No `columnKey` enum on Card. The Kanban columns are people + a
//   Backlog bucket (assignee IS NULL), so `assigneeId` already IS the
//   column dimension; a separate columnKey would just duplicate it.
//   `cards.move({ id, toAssigneeId, toPosition })` matches this shape.
// - "Complete" and "Archive" collapse into one `archivedAt` timestamp.
//   Admin metrics derive cycle time from `createdAt → archivedAt`. If
//   distinguishing the reason becomes useful later, add an enum then.
//
// Postgres specifics:
// - DateTime maps to timestamptz by default. The exceptions are
//   assignmentDate / dueDate, which use @db.Date (calendar dates,
//   no time-of-day, no zone).
// - Json maps to jsonb for the AuditLog before/after fields.
// - The partial index `WHERE "archivedAt" IS NULL` on Card is the
//   primary board-fetch index; added via raw SQL in the init
//   migration since Prisma's @@index can't express a WHERE clause.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URL moved to prisma.config.ts (datasource.url).
  // Runtime (PrismaClient) gets the URL from process.env.DATABASE_URL via
  // the PrismaPg adapter — see lib/db.ts.
}

enum Role {
  ANALYST
  ESTIMATOR
  SCHEDULER
  COMMERCIAL_MANAGER
  ADMIN
}

enum TaskType {
  ESTIMATE
  SCHEDULE
  OTHER
}

model Person {
  id         String    @id @default(cuid())
  name       String
  email      String?   @unique // used for NextAuth sign-in matching
  role       Role      @default(ANALYST)
  color      String // hex (#rrggbb); palette enforced at the app layer, not at DB
  active     Boolean   @default(true)
  // Display order on the board + admin People page. Manager-controlled via
  // up/down arrows on /admin/people, persisted here so the order survives
  // page reloads and sticks across users. Sequential integers; reorder is
  // a neighbor swap, no gaps needed at the 4-8 user scale.
  position   Int       @default(0)
  // High-water mark for the bell badge — the most recent moment this user
  // acknowledged their notifications. audit.listForUser({ since }) defaults
  // to lastSeenAt and prefs.markRead bumps it to now(). Nullable for fresh
  // accounts so the first sign-in shows every event affecting them.
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  assignedCards Card[]          @relation("CardAssignee")
  allowlistedBy AllowedUser[]   @relation("AllowedUserAddedBy")
  preference    UserPreference?
  auditEvents   AuditLog[]      @relation("AuditLogActor")

  @@index([active])
  @@index([position])
}

model Contract {
  id        String   @id @default(cuid())
  code      String   @unique // 1 uppercase letter + 5 digits, e.g. "N36054"
  name      String
  color     String? // optional; set via the Admin UI
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cards Card[]

  @@index([active])
}

model Card {
  id               String    @id @default(cuid())
  title            String
  type             TaskType
  assignmentDate   DateTime  @db.Date // basis for auto-priority aging (see lib/priority.ts)
  dueDate          DateTime  @db.Date
  priorityOverride Int? // 1..5; null = use auto-priority derived from assignmentDate
  blockerNote      String? // free-form blocker text shown on the card
  position         Int // ordering within the assignee bucket; integer-with-gaps (1000, 2000, ...)
  archivedAt       DateTime? // null = active board; non-null = archived / completed
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assigneeId String? // null = Backlog column
  assignee   Person?  @relation("CardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)
  // NOTE: the partial index `(assigneeId, position) WHERE archivedAt IS NULL`
  // — the primary board-fetch index — is created via raw SQL in the
  // init migration. Prisma's @@index can't express WHERE clauses.

  // Filter for archived/active separation (the dominant board query is WHERE archivedAt IS NULL)
  @@index([archivedAt])
  // Contract filter chips
  @@index([contractId])
}

model AllowedUser {
  id        String   @id @default(cuid())
  email     String   @unique // stored lowercase; case-folded on insert
  role      Role     @default(ANALYST) // role to assign to the matching Person on first sign-in
  createdAt DateTime @default(now())

  addedById String?
  addedBy   Person? @relation("AllowedUserAddedBy", fields: [addedById], references: [id], onDelete: SetNull)
}

model UserPreference {
  userId    String   @id // FK Person, also PK — one prefs row per person
  user      Person   @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme     String   @default("soft") // "soft" | "bold" | "bold-noir" | "bold-forest"
  layout    String   @default("columns") // "columns" | "swimlanes"
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String // e.g. "Card", "Person", "Contract", "AllowedUser"
  entityId   String // cuid of the row that changed
  action     String // "create" | "update" | "archive" | "restore" | "delete"
  before     Json? // jsonb — partial of the entity before the mutation
  after      Json? // jsonb — partial of the entity after the mutation
  createdAt  DateTime @default(now())

  actorId String?
  actor   Person? @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  // History query — chronological per entity
  @@index([entityType, entityId, createdAt(sort: Desc)])
  // Notifications feed — chronological per actor
  @@index([actorId, createdAt(sort: Desc)])
}
