// ConBon — Phase 2 data model
//
// ID strategy: cuid() for all primary keys. cuid() is shorter than uuid,
// roughly sortable by creation time, URL-safe, and Prisma's default —
// fine for an internal app with no public ID surface.
//
// Divergence from PLAN.md's schema sketch (intentional):
// - No `columnKey` enum on Card. The prototype's column model is
//   "Backlog (assignee IS NULL) + one column/lane per Person", so
//   `assigneeId` already IS the column dimension. A separate
//   columnKey would duplicate the signal. PLAN.md flagged this with
//   a "confirm from prototype" caveat; confirmed against board.jsx.
// - "Complete" and "Archive" collapse into one `archivedAt` timestamp
//   per PLAN.md Phase 6. Admin metrics in Phase 9 derive cycle time
//   from createdAt → archivedAt.
//
// Postgres specifics:
// - DateTime maps to timestamptz by default (correct for everything
//   except assignmentDate/dueDate, which use @db.Date — calendar
//   dates without time-of-day or zone).
// - Json maps to jsonb for the AuditLog before/after fields.
// - Partial index `WHERE "archivedAt" IS NULL` on Card is added via
//   raw SQL appended to the init migration (Prisma's @@index can't
//   express a WHERE clause).

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URL moved to prisma.config.ts (datasource.url).
  // Runtime (PrismaClient) gets the URL from process.env.DATABASE_URL via
  // the PrismaPg adapter — see lib/db.ts.
}

enum Role {
  EMPLOYEE
  ADMIN
  MANAGER
}

enum TaskType {
  ESTIMATE
  SCHEDULE
  OTHER
}

model Person {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique // Phase 7 matches NextAuth sign-in against this
  role      Role     @default(EMPLOYEE)
  color     String // hex (#rrggbb); palette enforced in Admin UI (Phase 9), not at DB level
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedCards Card[]          @relation("CardAssignee")
  allowlistedBy AllowedUser[]   @relation("AllowedUserAddedBy")
  preference    UserPreference?
  auditEvents   AuditLog[]      @relation("AuditLogActor")

  @@index([active])
}

model Contract {
  id        String   @id @default(cuid())
  code      String   @unique // 1 uppercase letter + 5 digits, e.g. "N36054"
  name      String
  color     String? // optional; Admin UI may set in Phase 9
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cards Card[]

  @@index([active])
}

model Card {
  id               String    @id @default(cuid())
  title            String
  type             TaskType
  assignmentDate   DateTime  @db.Date // basis for auto-priority aging (see lib/priority.ts, Phase 5)
  dueDate          DateTime  @db.Date
  priorityOverride Int? // 1..5; null = use auto-priority derived from assignmentDate
  blockerNote      String? // free-form blocker text shown on the card
  position         Int // ordering within the assignee bucket; integer-with-gaps (1000, 2000, ...)
  archivedAt       DateTime? // null = active board; non-null = archived / completed
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assigneeId String? // null = Backlog column
  assignee   Person?  @relation("CardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)
  // NOTE: the partial index `(assigneeId, position) WHERE archivedAt IS NULL`
  // — the primary board-fetch index — is created via raw SQL in the
  // init migration. Prisma's @@index can't express WHERE clauses.

  // Filter for archived/active separation (the dominant board query is WHERE archivedAt IS NULL)
  @@index([archivedAt])
  // Contract filter chips
  @@index([contractId])
}

model AllowedUser {
  id        String   @id @default(cuid())
  email     String   @unique // store lowercase; Phase 7 case-folds on insert
  role      Role     @default(EMPLOYEE) // role to assign to the matching Person on first sign-in
  createdAt DateTime @default(now())

  addedById String?
  addedBy   Person? @relation("AllowedUserAddedBy", fields: [addedById], references: [id], onDelete: SetNull)
}

model UserPreference {
  userId    String   @id // FK Person, also PK — one prefs row per person
  user      Person   @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme     String   @default("soft") // "soft" | "bold" | "bold-noir" | "bold-forest" (see Phase 11)
  layout    String   @default("columns") // "columns" | "swimlanes"
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String // e.g. "Card", "Person", "Contract", "AllowedUser"
  entityId   String // cuid of the row that changed
  action     String // "create" | "update" | "archive" | "restore" | "delete"
  before     Json? // jsonb — partial of the entity before the mutation
  after      Json? // jsonb — partial of the entity after the mutation
  createdAt  DateTime @default(now())

  actorId String?
  actor   Person? @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  // History query — chronological per entity (Phase 10 HistoryModal)
  @@index([entityType, entityId, createdAt(sort: Desc)])
  // Notifications feed — chronological per actor (Phase 10 BellDropdown)
  @@index([actorId, createdAt(sort: Desc)])
}
