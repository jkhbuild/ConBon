# Copy to .env (gitignored) and adjust as needed.
#
# Local dev Postgres comes from docker-compose.dev.yml:
#   npm run db:up
DATABASE_URL="postgresql://conbon:conbon@localhost:5432/conbon"

# --- Phase 7: NextAuth (Auth.js v5) ----------------------------------------
#
# Base URL the app is served from. Auth.js builds OAuth callback URLs +
# its own redirects off this when set. Leave UNSET in dev — auth.ts has
# trustHost: true so the Host header is used automatically (handles
# autoPort fallback when 3000 is taken). Set explicitly in production.
# NEXTAUTH_URL="https://conbon.example.com"

# 32-byte hex used to sign the JWT session cookie. Generate fresh per env:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=""

# Google OAuth 2.0 Web Client credentials. Authorized redirect URI must be
# `<NEXTAUTH_URL>/api/auth/callback/google`. Leave empty in dev if you're
# using AUTH_DEV_USER_EMAIL — Google sign-in is just hidden then.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# First-boot manager. When AllowedUser is empty AND this is set, the
# instrumentation hook inserts this email as MANAGER on app start. Idempotent
# (no-op once the table has any row). Lowercase-folded.
BOOTSTRAP_MANAGER_EMAIL=""

# Dev-only Google bypass. When set AND NODE_ENV !== "production", the
# /signin page exposes a "Sign in as <email>" button that runs through the
# same allowlist + Person-upsert pipeline as a real Google sign-in. Useful
# before Google creds are wired. Has no effect in production builds.
AUTH_DEV_USER_EMAIL=""
