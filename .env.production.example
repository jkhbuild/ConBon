# ConBon — production environment variables.
#
# Copy to `.env.production` on the VPS (gitignored by .gitignore's .env*
# rule) and fill in the blanks. docker-compose reads this file via
# `--env-file .env.production`. Every var below is required unless marked
# optional — the compose file uses `${VAR:?...}` syntax that hard-fails on
# missing values, so a typo here surfaces at `docker compose up` time, not
# at runtime.
#
# Generate strong secrets fresh per environment. Never reuse dev values.

# --- Domain + TLS -----------------------------------------------------------

# Public hostname the app serves from. Must resolve to this VPS via an
# A/AAAA record before bringing up Caddy (Let's Encrypt validates with an
# HTTP-01 challenge on :80).
DOMAIN=conbon.example.com

# Contact email for the Let's Encrypt account. ACME notifications (cert
# expiration warnings if renewal ever stalls) go here.
ACME_EMAIL=ops@example.com

# --- Postgres ---------------------------------------------------------------

# Initial DB owner created by the postgres image's entrypoint. Used as
# the JWT signer + bell badge owner; rotating means a new role on the
# Postgres side too.
POSTGRES_USER=conbon
POSTGRES_DB=conbon
# REQUIRED — generate a random string, e.g.:
#   openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
POSTGRES_PASSWORD=

# App-side Prisma connection string. Hostname is the compose service name
# `postgres` (resolves over the internal docker network); never `localhost`
# from inside the app container.
DATABASE_URL=postgresql://conbon:REPLACE_WITH_POSTGRES_PASSWORD@postgres:5432/conbon

# --- Auth.js (NextAuth v5) --------------------------------------------------

# Public URL the app is served from. Auth.js builds OAuth callback URLs +
# its own redirects off this. Must match DOMAIN above (https://<DOMAIN>).
NEXTAUTH_URL=https://conbon.example.com

# 32-byte hex used to sign the JWT session cookie. Generate fresh:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=

# --- Google OAuth -----------------------------------------------------------

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Web
# client. The authorized redirect URI MUST be exactly:
#   https://<DOMAIN>/api/auth/callback/google
# Mismatch = "redirect_uri_mismatch" error on sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- First-deploy bootstrap -------------------------------------------------

# When AllowedUser is empty, the app inserts this email as MANAGER on the
# first Node-process boot. Idempotent — once any allowlist row exists,
# subsequent boots no-op. Set to the email the first manager will sign in
# with via Google; case is folded on insert.
BOOTSTRAP_MANAGER_EMAIL=manager@example.com
